#import "../conf.typ": *

= Теорема Лагранжа (без доказательства). Следствие 2.

#theorem(title: "Теорема Лагранжа")[
  Порядок любой подгруппы конечной группы является делителем порядка группы

  $ H " — подгруппа конечной группы " G -> |G| dots.v |H| $

]

#corollary(title: "2")[
  Если порядок конечной группы $G$ равен простому числу $p$, то группа $G$ циклическая.
]
