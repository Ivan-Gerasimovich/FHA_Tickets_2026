#import "../conf.typ": *

= Теорема Лагранжа (без доказательства). Следствие 1.

#theorem(title: "Теорема Лагранжа")[
  Порядок любой подгруппы конечной группы является делителем порядка группы
  
  $ H " — подгруппа конечной группы " G quad -> quad |G| dots.v |H|. $
]

#corollary(title: "1")[
  Порядок любого элемента конечной группы является делителем порядка группы.
]